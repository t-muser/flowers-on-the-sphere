# Generated build artifacts (genmake2 + make output, the mitgcmuv binaries,
# Fortran .o/.f object files, dependency files). The only file in each
# build_*/ that is hand-maintained / vendored is genmake_local.
build_atm/*
build_ocn/*
build_cpl/*
!build_atm/genmake_local
!build_ocn/genmake_local
!build_cpl/genmake_local

# Staged input bundle: copies of *.bin files from sibling MITgcm
# verification dirs. Regenerated by `scripts/build.py` against any local
# MITgcm checkout — not worth committing the ~10 MB.
inputs/

# Per-machine build provenance — paths and timestamps differ per build.
# Anyone reproducing the dataset re-runs `scripts/build.py` and gets a
# fresh one.
build_info.json

# Generated sweep configs — produced by `scripts/generate_sweep.py`,
# 180 deterministic JSON files with no provenance value beyond the
# generator itself. Committing them would clutter the repo.
configs/run_*.json
configs/manifest.json

# SLURM stdout/stderr logs (the parent .gitignore already filters
# logs/*.out / *.err but we keep this here for clarity).
slurm/logs/*.out
slurm/logs/*.err
