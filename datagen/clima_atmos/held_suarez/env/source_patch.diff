 struct DecayingProfile{TP}
     perturb::Bool
     thermo_params::TP
+    # flowers-on-the-sphere patch: per-corner IC seed plumbed via env var.
+    # ``-1`` means "stock deterministic perturbation"; values >= 0 select
+    # the GPU-safe seeded noise path below. Stored as Int so the struct
+    # has a concrete layout and gets captured into CUDA kernels cleanly
+    # (a Union{Int,Nothing} field would break GPU compilation).
+    ic_seed::Int
 end
 
 function DecayingProfile(;
@@ -16,12 +22,48 @@ function DecayingProfile(;
     thermo_params = nothing,
     params = nothing,
 )
+    ic_seed = let s = get(ENV, "HS_IC_SEED", "")
+        isempty(s) ? -1 : something(tryparse(Int, s), -1)
+    end
     if !isnothing(params)
-        return DecayingProfile(perturb, params.thermodynamics_params)
+        return DecayingProfile(perturb, params.thermodynamics_params, ic_seed)
+    end
+    return DecayingProfile(perturb, thermo_params, ic_seed)
+end
+
+# flowers-on-the-sphere patch:
+# Stock CliMA seeds the temperature IC with a deterministic
+# ``0.1 · sind(long) · mask(z<5km)`` bump. For our seeded sweep we
+# replace that bump with a pseudo-random, GPU-safe noise of the same
+# amplitude built from a 3-cosine sum on ``(seed, lat, long, z)``.
+# The seed is captured into the closure by the ``setup::DecayingProfile``
+# struct field — reading ENV or constructing a stateful RNG inside the
+# kernel would trip CUDA's "no Julia runtime calls on device" rule.
+#
+# The cosine-sum approximates a standard normal in the ``[-√3, √3]`` range;
+# distinct seeds produce decorrelated fields. When ``HS_IC_SEED`` is
+# unset (``ic_seed < 0``) we fall through to the stock bump.
+_perturb_dispatch(::DecayingProfile, coord::Geometry.AbstractPoint{FT}) where {FT} =
+    _temperature_perturbation(coord)
+
+function _perturb_dispatch(setup::DecayingProfile, coord::Geometry.LatLongZPoint{FT}) where {FT}
+    z_mask = coord.z < 5000
+    if setup.ic_seed < 0 || !z_mask
+        return FT(0.1) * sind(coord.long) * z_mask
     end
-    return DecayingProfile(perturb, thermo_params)
+    s    = FT(setup.ic_seed)
+    lat  = coord.lat
+    long = coord.long
+    z    = coord.z
+    a = cos(FT(12.9898) * lat + FT(78.233)  * long + FT(43.2581) * z + FT(1.0)  * s)
+    b = cos(FT(39.346)  * lat + FT(11.135)  * long + FT(73.156)  * z + FT(7.0)  * s)
+    c = cos(FT(53.71)   * long + FT(17.91)   * lat  + FT(91.41)   * z + FT(13.0) * s)
+    n = (a + b + c) / sqrt(FT(3))
+    return FT(0.1) * n
 end
 
+# Original coord-only dispatch (kept for non-spherical setups that do
+# not need seeding).
 _temperature_perturbation(coord::Geometry.LatLongZPoint{FT}) where {FT} =
     FT(0.1) * sind(coord.long) * (coord.z < 5000)
 _temperature_perturbation(coord::Geometry.XZPoint{FT}) where {FT} =
@@ -45,7 +87,7 @@ function center_initial_condition(setup::DecayingProfile, local_geometry, params
     (; z) = local_geometry.coordinates
     T, p = temp_profile(thermo_params, z)
     if setup.perturb
-        T += _temperature_perturbation(local_geometry.coordinates)
+        T += _perturb_dispatch(setup, local_geometry.coordinates)
     end
 
     return physical_state(; T, p)
