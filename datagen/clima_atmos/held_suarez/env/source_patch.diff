+# flowers-on-the-sphere patch:
+# Reads an HS timescale (in days) from an ENV var and returns it in
+# seconds, falling back to ``default_days`` if the var is missing or
+# unparseable. ENV-var transport is intentional — it lets a single
+# Julia process pick its corner's timescales without forking
+# ClimaAtmos's TOML-/ClimaParams-based parameter system.
+function _hs_tau_seconds(env_name::AbstractString, default_days::Real, day::Real)
+    s = get(ENV, env_name, "")
+    isempty(s) && return default_days * day
+    val = tryparse(Float64, s)
+    val === nothing && return default_days * day
+    return val * day
+end
