# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Locally-built source dependencies (e.g. torch-harmonics CUDA rebuild)
third_party/

# SLURM logs
slurm/*.out
slurm/*.err
datagen/**/slurm/logs/*.out
datagen/**/slurm/logs/*.err

# Datagen-generated run configs and local data paths
datagen/**/configs/
datagen/uv.lock
/data/

runs/
.claude
.python_version
notebooks/*.mp4
/slurm/

# MITgcm build outputs (per-component build dirs keep only `genmake_local`).
datagen/**/build_atm/*
datagen/**/build_ocn/*
datagen/**/build_cpl/*
!datagen/**/build_atm/genmake_local
!datagen/**/build_ocn/genmake_local
!datagen/**/build_cpl/genmake_local
datagen/**/build_info.json
datagen/**/inputs/

**/.ipynb_checkpoints/